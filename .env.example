# =============================================================================
# Polymarket Copy Trading Bot – Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- Required: Wallet & chain ---
# Your EOA private key (MetaMask export). Used to sign orders. Keep secret.
PRIVATE_KEY=0x_your_private_key_here

# Polymarket proxy (smart) wallet address for this EOA. Find it in Polymarket UI
# or run: npm run balance (shows proxy wallet after first run with valid PRIVATE_KEY).
PROXY_WALLET_ADDRESS=0x_your_proxy_wallet_address

# Chain: 137 = Polygon mainnet, 80002 = Amoy testnet
CHAIN_ID=137

# --- RPC (optional; defaults work for Polygon) ---
# Full RPC URL. If set, RPC_TOKEN is ignored. Use https (not wss) for this bot.
# RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Or set only the token to use default Alchemy URLs:
# RPC_TOKEN=your_alchemy_api_key

# --- Trading ---
# Order type: FAK (fill-and-kill) or FOK (fill-or-kill)
ORDER_TYPE=FAK
# Price tick: 0.1 | 0.01 | 0.001 | 0.0001
TICK_SIZE=0.01
# Use negative-risk exchange
# NEG_RISK=false

# Order size meaning: true = config.json values are token counts; false = USDC (or use balance)
ORDER_SIZE_IN_TOKENS=true
# Optional: treat config.json amounts as fixed USDC (no price fetch)
# ORDER_SIZE_IN_USDC=false

# Enable copy trading (index / copytrade-api). Set false to disable.
# ENABLE_COPY_TRADING=true
# Copy is always inverse: target BUY -> you SELL; target SELL -> you BUY (no normal-follow mode).
# Only 5m/15m crypto (slug/title). Set false to allow any market the API/WS sends.
# COPY_TRADE_FILTER_CRYPTO_5M15M=true
# Enable terminal dashboard UI (realtime stats + asset chart)
# ENABLE_TERMINAL_DASHBOARD=true

# Set to false to place real buy/sell orders. When true (default), bot only logs (no orders).
DRY_RUN=false

# Auto-redeem interval in minutes (empty or 0 = disabled)
# REDEEM_DURATION=120

# --- API copy-trade (copytrade-api.ts) ---
# Poll interval in ms when using API polling
# POLL_INTERVAL_MS=30000
# Delay in ms between wallet API requests (rate limit)
# WALLET_FETCH_DELAY_MS=800
# Activity rows per wallet per request (default 40, max 100)
# ACTIVITY_FETCH_LIMIT=40

# Slippage: BUY = basis points above trade price (e.g. 200 = 2%); SELL = below mid
# BUY_SLIPPAGE_BPS=200
# SELL_SLIPPAGE_BPS=100

# --- Copy-trade thresholds ---
# Only copy BUY when target trade token price is above this (e.g. 0.45)
BUY_THRESHOLD=0.45
# Risk: sell when token price drops below this
SELL_PRICE=0.35
# Take profit: sell when token price reaches this
PROFIT_SELL_THRESHOLD=0.99
# Pending BUY: buy only after this many seconds past the 5m boundary (e.g. 160)
# PENDING_BUY_TIME_THRESHOLD_SECONDS=210

# Order retries
# ORDER_RETRY_ATTEMPTS=5
# ORDER_RETRY_DELAY_MS=200

# --- Real-time (WebSocket) ---
# Polymarket WebSocket URL (default is production)
# USER_REAL_TIME_DATA_URL=wss://ws-live-data.polymarket.com

# --- Telegram (optional) ---
# Notifications when target wallet trades. Leave empty to disable.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- CLOB API (optional) ---
# CLOB_API_URL=https://clob.polymarket.com

# --- Debug / scripts ---
# DEBUG=false
# For manual redeem script only:
# CONDITION_ID=
# INDEX_SETS=
